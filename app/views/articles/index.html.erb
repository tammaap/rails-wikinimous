<div class="container mb-3 mt-3 d-flex justify-content-between">
  <h2 class="">All Articles</h1>

  <%= link_to "New Article", new_article_path, class: "btn btn-primary mb-3" %>
</div>

<div class="container mb-3" id="articles">
  <ul class="list-group">
    <% @articles.each do |article| %>
      <li class="list-group-item">
        <h5>
          <%= link_to article.title, article_path(article), class:"text-decoration-none"%>
        </h5>
        <p>
          <%= truncate(article.content, length: 100) %>
        </p>
      </li>
    <% end %>
  </ul>
</div>
